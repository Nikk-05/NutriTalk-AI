# FastAPI AI Service Environment
PORT=8000

# AI Provider — choose one or both
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=gemini        # "gemini" | "openai"
AI_MODEL=gemini-1.5-flash # gemini-1.5-flash | gpt-4o | gpt-4o-mini

# Node.js API (for internal auth verification if needed)
NODE_API_URL=http://localhost:3000

# JWT secret (same as Node.js — to verify tokens directly)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this

# CORS — allow Node.js and frontend
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Streaming
STREAM_CHUNK_DELAY_MS=0
